#:kivy 2.0
#:import Window kivy.core.window.Window

# ════════════════════════════════════════════════════════════════
#  SNAKE PUZZLE  —  CYBERPUNK TERMINAL UI
#  palette:
#    bg-dark   0.03, 0.04, 0.07   (near-black void)
#    bg-panel  0.06, 0.07, 0.12
#    neon-grn  0.10, 1.00, 0.55   (matrix green)
#    neon-cyn  0.00, 0.85, 1.00   (cyan highlight)
#    neon-prp  0.72, 0.10, 1.00   (portal violet)
#    neon-red  1.00, 0.22, 0.30   (danger red)
#    neon-gld  1.00, 0.82, 0.10   (gold win)
#    dim-txt   0.35, 0.42, 0.55
# ════════════════════════════════════════════════════════════════

# ── reusable button widgets ──────────────────────────────────────

<NeonButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 0.10, 1.00, 0.55, 1
    font_size: 15
    bold: True
    canvas.before:
        # fill
        Color:
            rgba: 0.10, 1.00, 0.55, 0.06
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [4]
        # glow border
        Color:
            rgba: 0.10, 1.00, 0.55, 0.80 if self.state == 'down' else 0.45
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 4
            width: 1.8
        # corner accents top-left
        Color:
            rgba: 0.10, 1.00, 0.55, 1
        Line:
            points: self.x, self.top-10, self.x, self.top, self.x+10, self.top
            width: 2
        # corner accents bottom-right
        Line:
            points: self.right-10, self.y, self.right, self.y, self.right, self.y+10
            width: 2

<CyanButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 0.00, 0.85, 1.00, 1
    font_size: 15
    bold: True
    canvas.before:
        Color:
            rgba: 0.00, 0.85, 1.00, 0.06
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [4]
        Color:
            rgba: 0.00, 0.85, 1.00, 0.80 if self.state == 'down' else 0.45
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 4
            width: 1.8
        Color:
            rgba: 0.00, 0.85, 1.00, 1
        Line:
            points: self.x, self.top-10, self.x, self.top, self.x+10, self.top
            width: 2
        Line:
            points: self.right-10, self.y, self.right, self.y, self.right, self.y+10
            width: 2

<DangerButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 1.00, 0.22, 0.30, 1
    font_size: 15
    bold: True
    canvas.before:
        Color:
            rgba: 1.00, 0.22, 0.30, 0.08
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [4]
        Color:
            rgba: 1.00, 0.22, 0.30, 0.80 if self.state == 'down' else 0.45
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 4
            width: 1.8
        Color:
            rgba: 1.00, 0.22, 0.30, 1
        Line:
            points: self.x, self.top-10, self.x, self.top, self.x+10, self.top
            width: 2
        Line:
            points: self.right-10, self.y, self.right, self.y, self.right, self.y+10
            width: 2

<GhostButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 0.35, 0.42, 0.55, 1
    font_size: 13
    canvas.before:
        Color:
            rgba: 0.35, 0.42, 0.55, 0.15
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [4]
        Color:
            rgba: 0.35, 0.42, 0.55, 0.35
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 4
            width: 1

<PortalButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 0.72, 0.10, 1.00, 1
    font_size: 15
    bold: True
    canvas.before:
        Color:
            rgba: 0.72, 0.10, 1.00, 0.07
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [4]
        Color:
            rgba: 0.72, 0.10, 1.00, 0.80 if self.state == 'down' else 0.45
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 4
            width: 1.8
        Color:
            rgba: 0.72, 0.10, 1.00, 1
        Line:
            points: self.x, self.top-10, self.x, self.top, self.x+10, self.top
            width: 2
        Line:
            points: self.right-10, self.y, self.right, self.y, self.right, self.y+10
            width: 2

<GoldButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 1.00, 0.82, 0.10, 1
    font_size: 15
    bold: True
    canvas.before:
        Color:
            rgba: 1.00, 0.82, 0.10, 0.07
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [4]
        Color:
            rgba: 1.00, 0.82, 0.10, 0.80 if self.state == 'down' else 0.45
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 4
            width: 1.8
        Color:
            rgba: 1.00, 0.82, 0.10, 1
        Line:
            points: self.x, self.top-10, self.x, self.top, self.x+10, self.top
            width: 2
        Line:
            points: self.right-10, self.y, self.right, self.y, self.right, self.y+10
            width: 2

<LevelButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 0.10, 1.00, 0.55, 1
    font_size: 26
    bold: True
    canvas.before:
        Color:
            rgba: (0.10, 1.00, 0.55, 0.12) if self.state == 'down' else (0.10, 1.00, 0.55, 0.05)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [6]
        Color:
            rgba: (0.10, 1.00, 0.55, 1.0) if self.state == 'down' else (0.10, 1.00, 0.55, 0.40)
        Line:
            rounded_rectangle: self.x+2, self.y+2, self.width-4, self.height-4, 6
            width: 1.5
        Color:
            rgba: (0.10, 1.00, 0.55, 1)
        Line:
            points: self.x+2, self.top-8, self.x+2, self.top-2, self.x+8, self.top-2
            width: 1.5
        Line:
            points: self.right-8, self.y+2, self.right-2, self.y+2, self.right-2, self.y+8
            width: 1.5

# ════════════════════════════════════════════════════════════════
#  MENU SCREEN
# ════════════════════════════════════════════════════════════════
<MenuScreen>:
    canvas.before:
        # base void
        Color:
            rgba: 0.03, 0.04, 0.07, 1
        Rectangle:
            pos: self.pos
            size: self.size
        # deep glow bloom center
        Color:
            rgba: 0.10, 1.00, 0.55, 0.035
        Ellipse:
            pos: self.center_x - 380, self.center_y - 280
            size: 760, 560
        Color:
            rgba: 0.10, 1.00, 0.55, 0.025
        Ellipse:
            pos: self.center_x - 180, self.center_y - 130
            size: 360, 260
        # corner brackets
        Color:
            rgba: 0.10, 1.00, 0.55, 0.22
        Line:
            points: 20, self.height-20, 20, self.height-60
            width: 2
        Line:
            points: 20, self.height-20, 60, self.height-20
            width: 2
        Line:
            points: self.width-20, self.height-20, self.width-60, self.height-20
            width: 2
        Line:
            points: self.width-20, self.height-20, self.width-20, self.height-60
            width: 2
        Line:
            points: 20, 20, 60, 20
            width: 2
        Line:
            points: 20, 20, 20, 60
            width: 2
        Line:
            points: self.width-20, 20, self.width-60, 20
            width: 2
        Line:
            points: self.width-20, 20, self.width-20, 60
            width: 2

    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'

        BoxLayout:
            orientation: 'vertical'
            spacing: 0
            size_hint: None, None
            size: 360, 500
            padding: [0, 0, 0, 0]

            # ── LOGO BLOCK ───────────────────────────────────────
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: 190
                spacing: 2

                # snake emoji
                Label:
                    text: '🐍'
                    font_size: 48
                    size_hint_y: None
                    height: 68

                # SNAKE title
                Label:
                    text: 'SNAKE'
                    font_size: 46
                    bold: True
                    color: 0.10, 1.00, 0.55, 1
                    size_hint_y: None
                    height: 62
                    canvas.before:
                        Color:
                            rgba: 0.10, 1.00, 0.55, 0.08
                        Rectangle:
                            pos: self.x + self.width*0.15, self.y + 4
                            size: self.width*0.70, self.height - 8

                # subtitle pill
                Label:
                    text: '[ P U Z Z L E ]'
                    font_size: 13
                    color: 0.00, 0.85, 1.00, 0.90
                    size_hint_y: None
                    height: 32
                    canvas.before:
                        Color:
                            rgba: 0.00, 0.85, 1.00, 0.10
                        RoundedRectangle:
                            pos: self.center_x - 88, self.y + 6
                            size: 176, 22
                            radius: [4]

            # ── DIVIDER ──────────────────────────────────────────
            Widget:
                size_hint_y: None
                height: 26
                canvas:
                    Color:
                        rgba: 0.10, 1.00, 0.55, 0.55
                    Line:
                        points: 0, self.center_y, 36, self.center_y
                        width: 1.2
                    Color:
                        rgba: 0.10, 1.00, 0.55, 0.18
                    Line:
                        points: 36, self.center_y, self.width - 36, self.center_y
                        width: 1
                    Color:
                        rgba: 0.10, 1.00, 0.55, 0.55
                    Line:
                        points: self.width - 36, self.center_y, self.width, self.center_y
                        width: 1.2

            Widget:
                size_hint_y: None
                height: 12

            # ── BUTTONS ──────────────────────────────────────────
            NeonButton:
                text: '▶   START GAME'
                size_hint_y: None
                height: 56
                font_size: 16
                on_press: root.manager.current = 'game'

            Widget:
                size_hint_y: None
                height: 10

            PortalButton:
                text: '⊞   SELECT LEVEL'
                size_hint_y: None
                height: 50
                on_press: root.manager.current = 'select_level'

            Widget:
                size_hint_y: None
                height: 10

            DangerButton:
                text: '⏻   EXIT'
                size_hint_y: None
                height: 50
                on_press: app.stop()

            Widget:
                size_hint_y: None
                height: 18

            # version / hint
            Label:
                text: 'SYS v1.0  ·  ARROW KEYS TO NAVIGATE'
                font_size: 10
                color: 0.20, 0.26, 0.35, 1
                size_hint_y: None
                height: 16


# ════════════════════════════════════════════════════════════════
#  GAME SCREEN
# ════════════════════════════════════════════════════════════════
<GameScreen>:
    canvas.before:
        Color:
            rgba: 0.03, 0.04, 0.07, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        spacing: 0

        # ── HUD TOP BAR ──────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: 50
            padding: [14, 0, 14, 0]
            spacing: 0
            canvas.before:
                Color:
                    rgba: 0.05, 0.06, 0.10, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                # top separator glow
                Color:
                    rgba: 0.10, 1.00, 0.55, 0.50
                Line:
                    points: self.x, self.y, self.right, self.y
                    width: 1.5
                # faint second line
                Color:
                    rgba: 0.10, 1.00, 0.55, 0.10
                Line:
                    points: self.x, self.y - 2, self.right, self.y - 2
                    width: 1

            # LEVEL badge
            BoxLayout:
                size_hint_x: None
                width: 150
                spacing: 6

                Widget:
                    size_hint_x: None
                    width: 20
                    canvas:
                        Color:
                            rgba: 0.10, 1.00, 0.55, 1
                        Line:
                            points: self.center_x - 6, self.center_y - 6, self.center_x, self.center_y + 6, self.center_x + 6, self.center_y - 6, self.center_x - 6, self.center_y - 6
                            width: 1.5

                Label:
                    id: level_label
                    text: 'LEVEL  1'
                    font_size: 14
                    bold: True
                    color: 0.85, 0.92, 1.00, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            Widget:

            # APPLE counter
            BoxLayout:
                size_hint_x: None
                width: 180
                spacing: 6

                Label:
                    text: '🍎'
                    font_size: 15
                    size_hint_x: None
                    width: 26

                Label:
                    id: apple_label
                    text: 'APPLES LEFT: 1'
                    font_size: 12
                    color: 1.00, 0.40, 0.45, 1
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size

        # ── GAME BOARD ───────────────────────────────────────────
        GameBoard:
            id: game_board

        # ── BOTTOM CONTROL BAR ───────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: 52
            spacing: 10
            padding: [14, 8, 14, 8]
            canvas.before:
                Color:
                    rgba: 0.05, 0.06, 0.10, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                # top separator
                Color:
                    rgba: 0.10, 1.00, 0.55, 0.30
                Line:
                    points: self.x, self.top, self.right, self.top
                    width: 1

            GhostButton:
                text: '⏸  PAUSE'
                size_hint_x: 0.25
                on_press: game_board.toggle_pause()

            NeonButton:
                text: '↺  RESTART'
                size_hint_x: 0.42
                on_press:
                    game_board.engine.reset_level()
                    game_board.redraw()

            GhostButton:
                text: '⌂  MENU'
                size_hint_x: 0.25
                on_press: root.manager.current = 'menu'

    # ── PAUSE OVERLAY ────────────────────────────────────────────
    BoxLayout:
        id: pause_layout
        orientation: 'vertical'
        opacity: 0
        disabled: True
        pos_hint: {'center_y': 0.5} if self.opacity == 1 else {'center_y': 5.0}
        spacing: 18
        padding: [60, 90, 60, 90]
        canvas.before:
            Color:
                rgba: 0.03, 0.04, 0.07, 0.92
            Rectangle:
                pos: self.pos
                size: self.size
            # corner brackets
            Color:
                rgba: 0.10, 1.00, 0.55, 0.35
            Line:
                points: 24, self.height-24, 24, self.height-64
                width: 2
            Line:
                points: 24, self.height-24, 64, self.height-24
                width: 2
            Line:
                points: self.width-24, 24, self.width-64, 24
                width: 2
            Line:
                points: self.width-24, 24, self.width-24, 64
                width: 2

        Label:
            text: '⏸'
            font_size: 52
            color: 0.00, 0.85, 1.00, 0.60
            size_hint_y: None
            height: 70

        Label:
            text: 'PAUSED'
            font_size: 52
            bold: True
            color: 0.85, 0.92, 1.00, 1
            letter_spacing: 10
            size_hint_y: None
            height: 74

        Label:
            text: 'system halted  ·  awaiting input'
            font_size: 13
            color: 0.25, 0.35, 0.50, 1
            size_hint_y: None
            height: 36

        Widget:
            size_hint_y: None
            height: 20

        AnchorLayout:
            size_hint_y: None
            height: 58
            anchor_x: 'center'
            CyanButton:
                text: '▶   RESUME'
                size_hint: None, None
                size: 260, 52
                on_press: game_board.toggle_pause()

        AnchorLayout:
            size_hint_y: None
            height: 58
            anchor_x: 'center'
            GhostButton:
                text: '⌂   MAIN MENU'
                size_hint: None, None
                size: 260, 52
                on_press:
                    root.manager.current = 'menu'
                    game_board.toggle_pause()

    # ── GAME OVER OVERLAY ────────────────────────────────────────
    BoxLayout:
        id: game_over_layout
        orientation: 'vertical'
        opacity: 0
        disabled: True
        pos_hint: {'center_y': 0.5} if self.opacity == 1 else {'center_y': 5.0}
        spacing: 16
        padding: [60, 90, 60, 90]
        canvas.before:
            Color:
                rgba: 0.07, 0.02, 0.03, 0.94
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 1.00, 0.22, 0.30, 0.04
            Rectangle:
                pos: self.pos
                size: self.size
            # corner brackets red
            Color:
                rgba: 1.00, 0.22, 0.30, 0.50
            Line:
                points: 24, self.height-24, 24, self.height-64
                width: 2
            Line:
                points: 24, self.height-24, 64, self.height-24
                width: 2
            Line:
                points: self.width-24, 24, self.width-64, 24
                width: 2
            Line:
                points: self.width-24, 24, self.width-24, 64
                width: 2

        Label:
            text: '💀'
            font_size: 58
            size_hint_y: None
            height: 76

        Label:
            text: 'GAME OVER'
            font_size: 52
            bold: True
            color: 1.00, 0.22, 0.30, 1
            letter_spacing: 8
            size_hint_y: None
            height: 74

        Label:
            text: 'you fell into the void'
            font_size: 14
            color: 0.60, 0.30, 0.35, 1
            size_hint_y: None
            height: 36

        Widget:
            size_hint_y: None
            height: 20

        AnchorLayout:
            size_hint_y: None
            height: 58
            anchor_x: 'center'
            DangerButton:
                text: '↻   TRY AGAIN'
                size_hint: None, None
                size: 260, 52
                on_press:
                    game_board.engine.reset_level()
                    game_board.redraw()

        AnchorLayout:
            size_hint_y: None
            height: 58
            anchor_x: 'center'
            GhostButton:
                text: '⌂   MAIN MENU'
                size_hint: None, None
                size: 260, 52
                on_press:
                    root.manager.current = 'menu'
                    game_board.engine.reset_level()
                    game_board.redraw()

    # ── LEVEL CLEARED OVERLAY ────────────────────────────────────
    BoxLayout:
        id: level_complete_layout
        orientation: 'vertical'
        opacity: 0
        disabled: True
        pos_hint: {'center_y': 0.5} if self.opacity == 1 else {'center_y': 5.0}
        spacing: 16
        padding: [60, 90, 60, 90]
        canvas.before:
            Color:
                rgba: 0.02, 0.07, 0.05, 0.94
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 0.10, 1.00, 0.55, 0.04
            Rectangle:
                pos: self.pos
                size: self.size
            # corner brackets green
            Color:
                rgba: 0.10, 1.00, 0.55, 0.50
            Line:
                points: 24, self.height-24, 24, self.height-64
                width: 2
            Line:
                points: 24, self.height-24, 64, self.height-24
                width: 2
            Line:
                points: self.width-24, 24, self.width-64, 24
                width: 2
            Line:
                points: self.width-24, 24, self.width-24, 64
                width: 2

        Label:
            text: '✔'
            font_size: 58
            color: 0.10, 1.00, 0.55, 1
            size_hint_y: None
            height: 76

        Label:
            text: 'LEVEL CLEARED'
            font_size: 48
            bold: True
            color: 0.10, 1.00, 0.55, 1
            letter_spacing: 6
            size_hint_y: None
            height: 74

        Label:
            text: 'ready for the next sequence?'
            font_size: 14
            color: 0.20, 0.60, 0.40, 1
            size_hint_y: None
            height: 36

        Widget:
            size_hint_y: None
            height: 20

        AnchorLayout:
            size_hint_y: None
            height: 58
            anchor_x: 'center'
            NeonButton:
                text: '▶   NEXT LEVEL'
                size_hint: None, None
                size: 260, 52
                on_press:
                    game_board.engine.next_level()
                    game_board.redraw()

        AnchorLayout:
            size_hint_y: None
            height: 58
            anchor_x: 'center'
            GhostButton:
                text: '⌂   MAIN MENU'
                size_hint: None, None
                size: 260, 52
                on_press:
                    root.manager.current = 'menu'
                    game_board.engine.reset_level()
                    game_board.redraw()

    # ── GAME WON OVERLAY ─────────────────────────────────────────
    BoxLayout:
        id: game_won_layout
        orientation: 'vertical'
        opacity: 0
        disabled: True
        pos_hint: {'center_y': 0.5} if self.opacity == 1 else {'center_y': 5.0}
        spacing: 16
        padding: [60, 90, 60, 90]
        canvas.before:
            Color:
                rgba: 0.06, 0.05, 0.02, 0.94
            Rectangle:
                pos: self.pos
                size: self.size
            Color:
                rgba: 1.00, 0.82, 0.10, 0.04
            Rectangle:
                pos: self.pos
                size: self.size
            # corner brackets gold
            Color:
                rgba: 1.00, 0.82, 0.10, 0.60
            Line:
                points: 24, self.height-24, 24, self.height-64
                width: 2
            Line:
                points: 24, self.height-24, 64, self.height-24
                width: 2
            Line:
                points: self.width-24, 24, self.width-64, 24
                width: 2
            Line:
                points: self.width-24, 24, self.width-24, 64
                width: 2

        Label:
            text: '★ ★ ★'
            font_size: 52
            color: 1.00, 0.82, 0.10, 1
            size_hint_y: None
            height: 76

        Label:
            text: 'YOU WIN!'
            font_size: 56
            bold: True
            color: 1.00, 0.82, 0.10, 1
            letter_spacing: 10
            size_hint_y: None
            height: 80

        Label:
            text: 'all sequences completed  ·  puzzle master'
            font_size: 13
            color: 0.60, 0.52, 0.20, 1
            size_hint_y: None
            height: 36

        Widget:
            size_hint_y: None
            height: 20

        AnchorLayout:
            size_hint_y: None
            height: 58
            anchor_x: 'center'
            GoldButton:
                text: '↻   PLAY AGAIN'
                size_hint: None, None
                size: 260, 52
                on_press:
                    game_board.engine.restart_game()
                    game_board.redraw()

        AnchorLayout:
            size_hint_y: None
            height: 58
            anchor_x: 'center'
            GhostButton:
                text: '⌂   MAIN MENU'
                size_hint: None, None
                size: 260, 52
                on_press:
                    root.manager.current = 'menu'
                    game_board.engine.restart_game()
                    game_board.redraw()


# ════════════════════════════════════════════════════════════════
#  SELECT LEVEL SCREEN
# ════════════════════════════════════════════════════════════════
<SelectLevelScreen>:
    canvas.before:
        Color:
            rgba: 0.03, 0.04, 0.07, 1
        Rectangle:
            pos: self.pos
            size: self.size
        # glow bloom
        Color:
            rgba: 0.72, 0.10, 1.00, 0.03
        Ellipse:
            pos: self.center_x - 260, self.center_y - 200
            size: 520, 400
        # corner brackets
        Color:
            rgba: 0.72, 0.10, 1.00, 0.25
        Line:
            points: 20, self.height-20, 20, self.height-60
            width: 2
        Line:
            points: 20, self.height-20, 60, self.height-20
            width: 2
        Line:
            points: self.width-20, 20, self.width-60, 20
            width: 2
        Line:
            points: self.width-20, 20, self.width-20, 60
            width: 2

    BoxLayout:
        orientation: 'vertical'
        padding: [60, 36, 60, 36]
        spacing: 24

        # title row
        BoxLayout:
            size_hint_y: None
            height: 80
            orientation: 'vertical'
            spacing: 6

            Label:
                text: 'SELECT  LEVEL'
                font_size: 38
                bold: True
                color: 0.85, 0.92, 1.00, 1
                letter_spacing: 6
                size_hint_y: None
                height: 52

            Widget:
                size_hint_y: None
                height: 20
                canvas:
                    Color:
                        rgba: 0.72, 0.10, 1.00, 0.55
                    Line:
                        points: 0, self.center_y, 80, self.center_y
                        width: 1.5
                    Color:
                        rgba: 0.72, 0.10, 1.00, 0.18
                    Line:
                        points: 80, self.center_y, self.width - 80, self.center_y
                        width: 1
                    Color:
                        rgba: 0.72, 0.10, 1.00, 0.55
                    Line:
                        points: self.width - 80, self.center_y, self.width, self.center_y
                        width: 1.5

        # level grid
        GridLayout:
            cols: 3
            spacing: 20
            padding: [20, 10, 20, 10]

            LevelButton:
                text: '01'
                on_press: app.start_level(0)

            LevelButton:
                text: '02'
                on_press: app.start_level(1)

            LevelButton:
                text: '03'
                on_press: app.start_level(2)

            LevelButton:
                text: '04'
                on_press: app.start_level(3)

            LevelButton:
                text: '05'
                on_press: app.start_level(4)

            LevelButton:
                text: '06'
                on_press: app.start_level(5)

        Widget:
            size_hint_y: None
            height: 10

        AnchorLayout:
            size_hint_y: None
            height: 56
            anchor_x: 'center'
            GhostButton:
                text: '⌂   BACK TO MENU'
                size_hint: None, None
                size: 260, 50
                on_press: root.manager.current = 'menu'