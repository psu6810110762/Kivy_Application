#:kivy 2.0
#:import Window kivy.core.window.Window

# ── สีหลัก ──────────────────────────────────────────────────────────────────
# bg:      0.05, 0.05, 0.10  (ดำอมน้ำเงิน)
# panel:   0.08, 0.09, 0.16
# accent:  0.18, 0.90, 0.50  (เขียว neon)
# accent2: 0.75, 0.20, 1.00  (ม่วง portal)
# warn:    0.95, 0.25, 0.25  (แดง apple)
# text:    0.85, 0.90, 1.00

# ── reusable styles ──────────────────────────────────────────────────────────
<NeonButton@Button>:
    background_normal: ''
    background_color: 0.08, 0.09, 0.16, 1
    color: 0.18, 0.90, 0.50, 1
    font_size: 16
    bold: True
    canvas.before:
        Color:
            rgba: 0.18, 0.90, 0.50, 0.6
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 6
            width: 1.5

<DangerButton@Button>:
    background_normal: ''
    background_color: 0.08, 0.09, 0.16, 1
    color: 0.95, 0.35, 0.35, 1
    font_size: 16
    bold: True
    canvas.before:
        Color:
            rgba: 0.95, 0.35, 0.35, 0.5
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 6
            width: 1.5

<GhostButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 0.45, 0.50, 0.65, 1
    font_size: 14
    canvas.before:
        Color:
            rgba: 0.25, 0.28, 0.40, 0.6
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 6
            width: 1

# ── MenuScreen ───────────────────────────────────────────────────────────────
<MenuScreen>:
    canvas.before:
        Color:
            rgba: 0.05, 0.05, 0.10, 1
        Rectangle:
            pos: self.pos
            size: self.size
        # เส้น grid พื้นหลัง
        Color:
            rgba: 0.10, 0.11, 0.18, 1
        Line:
            width: 0.8
            points: 0, self.height*0.33, self.width, self.height*0.33
        Line:
            width: 0.8
            points: 0, self.height*0.66, self.width, self.height*0.66
        Line:
            width: 0.8
            points: self.width*0.33, 0, self.width*0.33, self.height
        Line:
            width: 0.8
            points: self.width*0.66, 0, self.width*0.66, self.height
        # glow ตรงกลาง
        Color:
            rgba: 0.18, 0.90, 0.50, 0.04
        Ellipse:
            pos: self.center_x - 300, self.center_y - 200
            size: 600, 400

    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'

        BoxLayout:
            orientation: 'vertical'
            spacing: 0
            size_hint: None, None
            size: 340, 480
            padding: [0, 0, 0, 0]

            # Logo area
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: 180
                spacing: 8

                # ตัวงูประดับ
                Label:
                    text: '🐍'
                    font_size: 52
                    size_hint_y: None
                    height: 70

                Label:
                    text: 'SNAKE'
                    font_size: 38
                    bold: True
                    color: 0.18, 0.90, 0.50, 1
                    size_hint_y: None
                    height: 50
                    canvas.before:
                        Color:
                            rgba: 0.18, 0.90, 0.50, 0.15
                        Rectangle:
                            pos: self.x + self.width*0.1, self.y
                            size: self.width*0.8, self.height

                Label:
                    text: 'P U Z Z L E'
                    font_size: 14
                    letter_spacing: 8
                    color: 0.45, 0.85, 0.65, 1
                    size_hint_y: None
                    height: 28

            # ตัวคั่น
            Widget:
                size_hint_y: None
                height: 24
                canvas:
                    Color:
                        rgba: 0.18, 0.90, 0.50, 0.3
                    Line:
                        points: 20, self.center_y, self.width-20, self.center_y
                        width: 1

            Widget:
                size_hint_y: None
                height: 16

            # ปุ่มเมนู
            NeonButton:
                text: '▶  START GAME'
                size_hint_y: None
                height: 54
                font_size: 17
                on_press: root.manager.current = 'game'

            Widget:
                size_hint_y: None
                height: 12

            GhostButton:
                text: '☰  SELECT LEVEL'
                size_hint_y: None
                height: 48

            Widget:
                size_hint_y: None
                height: 12

            DangerButton:
                text: '✕  EXIT'
                size_hint_y: None
                height: 48
                on_press: app.stop()

            Widget:
                size_hint_y: None
                height: 20

            # version label
            Label:
                text: 'v1.0  ·  use arrow keys'
                font_size: 11
                color: 0.25, 0.28, 0.40, 1
                size_hint_y: None
                height: 20


# ── GameScreen ───────────────────────────────────────────────────────────────
<GameScreen>:
    canvas.before:
        Color:
            rgba: 0.04, 0.04, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        spacing: 0

        # ── แถบบน (HUD) ──────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: 48
            padding: [16, 0, 16, 0]
            spacing: 0
            canvas.before:
                Color:
                    rgba: 0.06, 0.07, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.18, 0.90, 0.50, 0.25
                Line:
                    points: self.x, self.y, self.right, self.y
                    width: 1.5

            # Level badge
            BoxLayout:
                size_hint_x: None
                width: 120
                spacing: 6

                Label:
                    text: '◈'
                    font_size: 18
                    color: 0.18, 0.90, 0.50, 1
                    size_hint_x: None
                    width: 24

                Label:
                    id: level_label
                    text: 'LEVEL  1'
                    font_size: 15
                    bold: True
                    color: 0.85, 0.90, 1.00, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            Widget:

            # Apple counter
            BoxLayout:
                size_hint_x: None
                width: 160
                spacing: 6
                halign: 'right'

                Label:
                    text: '🍎'
                    font_size: 16
                    size_hint_x: None
                    width: 24

                Label:
                    id: apple_label
                    text: 'APPLES LEFT: 1'
                    font_size: 13
                    color: 0.95, 0.45, 0.45, 1
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size

        # ── พื้นที่เกม ────────────────────────────────────────────────────
        GameBoard:
            id: game_board

        # ── แถบล่าง ───────────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: 56
            spacing: 10
            padding: [16, 8, 16, 8]
            canvas.before:
                Color:
                    rgba: 0.06, 0.07, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.18, 0.90, 0.50, 0.15
                Line:
                    points: self.x, self.top, self.right, self.top
                    width: 1

            GhostButton:
                text: '⏸  PAUSE'
                size_hint_x: 0.25

            NeonButton:
                text: '↺  RESTART'
                size_hint_x: 0.40
                on_press:
                    game_board.engine.reset_level()
                    game_board.redraw()

            GhostButton:
                text: '⌂  MENU'
                size_hint_x: 0.25
                on_press: root.manager.current = 'menu'
