#:kivy 2.0
#:import Window kivy.core.window.Window

# ── สีหลัก ──────────────────────────────────────────────────────────────────
# bg:      0.05, 0.05, 0.10  (ดำอมน้ำเงิน)
# panel:   0.08, 0.09, 0.16
# accent:  0.18, 0.90, 0.50  (เขียว neon)
# accent2: 0.75, 0.20, 1.00  (ม่วง portal)
# warn:    0.95, 0.25, 0.25  (แดง apple)
# text:    0.85, 0.90, 1.00

# ── reusable styles ──────────────────────────────────────────────────────────
<NeonButton@Button>:
    background_normal: ''
    background_color: 0.08, 0.09, 0.16, 1
    color: 0.18, 0.90, 0.50, 1
    font_size: 16
    bold: True
    canvas.before:
        Color:
            rgba: 0.18, 0.90, 0.50, 0.6
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 6
            width: 1.5

<DangerButton@Button>:
    background_normal: ''
    background_color: 0.08, 0.09, 0.16, 1
    color: 0.95, 0.35, 0.35, 1
    font_size: 16
    bold: True
    canvas.before:
        Color:
            rgba: 0.95, 0.35, 0.35, 0.5
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 6
            width: 1.5

<GhostButton@Button>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    color: 0.45, 0.50, 0.65, 1
    font_size: 14
    canvas.before:
        Color:
            rgba: 0.25, 0.28, 0.40, 0.6
        Line:
            rounded_rectangle: self.x+1, self.y+1, self.width-2, self.height-2, 6
            width: 1

<LevelButton@Button>:
    background_normal: ''
    background_color: 0.08, 0.09, 0.16, 1
    color: 0.18, 0.90, 0.50, 1
    font_size: 28
    bold: True
    canvas.before:
        Color:
            rgba: (0.18, 0.90, 0.50, 0.6) if self.state == 'normal' else (0.95, 0.85, 0.20, 1)
        Line:
            rounded_rectangle: self.x+2, self.y+2, self.width-4, self.height-4, 12
            width: 1.5

# ── MenuScreen ───────────────────────────────────────────────────────────────
<MenuScreen>:
    canvas.before:
        Color:
            rgba: 0.05, 0.05, 0.10, 1
        Rectangle:
            pos: self.pos
            size: self.size
        # เส้น grid พื้นหลัง
        Color:
            rgba: 0.10, 0.11, 0.18, 1
        Line:
            width: 0.8
            points: 0, self.height*0.33, self.width, self.height*0.33
        Line:
            width: 0.8
            points: 0, self.height*0.66, self.width, self.height*0.66
        Line:
            width: 0.8
            points: self.width*0.33, 0, self.width*0.33, self.height
        Line:
            width: 0.8
            points: self.width*0.66, 0, self.width*0.66, self.height
        # glow ตรงกลาง
        Color:
            rgba: 0.18, 0.90, 0.50, 0.04
        Ellipse:
            pos: self.center_x - 300, self.center_y - 200
            size: 600, 400

    AnchorLayout:
        anchor_x: 'center'
        anchor_y: 'center'

        BoxLayout:
            orientation: 'vertical'
            spacing: 0
            size_hint: None, None
            size: 340, 480
            padding: [0, 0, 0, 0]

            # Logo area
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: 180
                spacing: 8

                # ตัวงูประดับ
                Label:
                    text: '🐍'
                    font_size: 52
                    size_hint_y: None
                    height: 70

                Label:
                    text: 'SNAKE'
                    font_size: 38
                    bold: True
                    color: 0.18, 0.90, 0.50, 1
                    size_hint_y: None
                    height: 50
                    canvas.before:
                        Color:
                            rgba: 0.18, 0.90, 0.50, 0.15
                        Rectangle:
                            pos: self.x + self.width*0.1, self.y
                            size: self.width*0.8, self.height

                Label:
                    text: 'P U Z Z L E'
                    font_size: 14
                    letter_spacing: 8
                    color: 0.45, 0.85, 0.65, 1
                    size_hint_y: None
                    height: 28

            # ตัวคั่น
            Widget:
                size_hint_y: None
                height: 24
                canvas:
                    Color:
                        rgba: 0.18, 0.90, 0.50, 0.3
                    Line:
                        points: 20, self.center_y, self.width-20, self.center_y
                        width: 1

            Widget:
                size_hint_y: None
                height: 16

            # ปุ่มเมนู
            NeonButton:
                text: '▶  START GAME'
                size_hint_y: None
                height: 54
                font_size: 17
                on_press: root.manager.current = 'game'

            Widget:
                size_hint_y: None
                height: 12

            GhostButton:
                text: '☰  SELECT LEVEL'
                size_hint_y: None
                height: 48
                on_press: root.manager.current = 'select_level'

            Widget:
                size_hint_y: None
                height: 12

            DangerButton:
                text: '✕  EXIT'
                size_hint_y: None
                height: 48
                on_press: app.stop()

            Widget:
                size_hint_y: None
                height: 20

            # version label
            Label:
                text: 'v1.0  ·  use arrow keys'
                font_size: 11
                color: 0.25, 0.28, 0.40, 1
                size_hint_y: None
                height: 20


# ── GameScreen ───────────────────────────────────────────────────────────────
<GameScreen>:
    canvas.before:
        Color:
            rgba: 0.04, 0.04, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        spacing: 0

        # ── แถบบน (HUD) ──────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: 48
            padding: [16, 0, 16, 0]
            spacing: 0
            canvas.before:
                Color:
                    rgba: 0.06, 0.07, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.18, 0.90, 0.50, 0.25
                Line:
                    points: self.x, self.y, self.right, self.y
                    width: 1.5

            # Level badge
            BoxLayout:
                size_hint_x: None
                width: 120
                spacing: 6

                Label:
                    text: '◈'
                    font_size: 18
                    color: 0.18, 0.90, 0.50, 1
                    size_hint_x: None
                    width: 24

                Label:
                    id: level_label
                    text: 'LEVEL  1'
                    font_size: 15
                    bold: True
                    color: 0.85, 0.90, 1.00, 1
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

            Widget:

            # Apple counter
            BoxLayout:
                size_hint_x: None
                width: 160
                spacing: 6
                halign: 'right'

                Label:
                    text: '🍎'
                    font_size: 16
                    size_hint_x: None
                    width: 24

                Label:
                    id: apple_label
                    text: 'APPLES LEFT: 1'
                    font_size: 13
                    color: 0.95, 0.45, 0.45, 1
                    halign: 'right'
                    valign: 'middle'
                    text_size: self.size

        # ── พื้นที่เกม ────────────────────────────────────────────────────
        GameBoard:
            id: game_board

        # ── แถบล่าง ───────────────────────────────────────────────────────
        BoxLayout:
            size_hint_y: None
            height: 56
            spacing: 10
            padding: [16, 8, 16, 8]
            canvas.before:
                Color:
                    rgba: 0.06, 0.07, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.18, 0.90, 0.50, 0.15
                Line:
                    points: self.x, self.top, self.right, self.top
                    width: 1

            GhostButton:
                text: '⏸  PAUSE'
                size_hint_x: 0.25
                on_press: game_board.toggle_pause()

            NeonButton:
                text: '↺  RESTART'
                size_hint_x: 0.40
                on_press:
                    game_board.engine.reset_level()
                    game_board.redraw()

            GhostButton:
                text: '⌂  MENU'
                size_hint_x: 0.25
                on_press: root.manager.current = 'menu'
            
    # ── หน้าต่าง Pause Overlay ──────────────────────────────────────────
    BoxLayout:
        id: pause_layout
        orientation: 'vertical'
        opacity: 0
        disabled: True
        # เลื่อนแผ่นนี้ออกนอกจอเวลาซ่อน
        pos_hint: {'center_y': 0.5} if self.opacity == 1 else {'center_y': 5.0}
        spacing: 20
        padding: [60, 100, 60, 100]
        canvas.before:
            Color:
                rgba: 0.04, 0.04, 0.08, 0.85  # พื้นหลังมืดโปร่งแสง
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: 'PAUSED'
            font_size: 56
            bold: True
            color: 0.85, 0.90, 1.00, 1
            letter_spacing: 8
            size_hint_y: None
            height: 80

        Label:
            text: 'Take a break and plan your next move...'
            font_size: 16
            color: 0.45, 0.50, 0.65, 1
            size_hint_y: None
            height: 40

        Widget:
            size_hint_y: None
            height: 30

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            NeonButton:
                text: '▶  RESUME'
                size_hint: None, None
                size: 240, 54
                on_press: game_board.toggle_pause()

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            GhostButton:
                text: '⌂  MAIN MENU'
                size_hint: None, None
                size: 240, 54
                on_press:
                    root.manager.current = 'menu'
                    game_board.toggle_pause()

    # ── หน้าต่าง Game Over Overlay ──────────────────────────────────────────
    BoxLayout:
        id: game_over_layout
        orientation: 'vertical'
        opacity: 0
        disabled: True
        # เลื่อนแผ่นนี้ออกนอกจอเวลาซ่อน
        pos_hint: {'center_y': 0.5} if self.opacity == 1 else {'center_y': 5.0}
        spacing: 20
        padding: [60, 100, 60, 100]
        canvas.before:
            Color:
                rgba: 0.08, 0.02, 0.02, 0.9  # พื้นหลังสีแดงเข้มโปร่งแสง
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: 'X_X'
            font_size: 64
            color: 0.95, 0.35, 0.35, 1
            size_hint_y: None
            height: 80

        Label:
            text: 'GAME OVER'
            font_size: 56
            bold: True
            color: 0.95, 0.35, 0.35, 1
            letter_spacing: 8
            size_hint_y: None
            height: 80

        Label:
            text: 'You fell into the abyss...'
            font_size: 16
            color: 0.65, 0.45, 0.50, 1
            size_hint_y: None
            height: 40

        Widget:
            size_hint_y: None
            height: 30

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            # ใช้ DangerButton สีแดงที่คุณเตรียมไว้
            DangerButton:
                text: '↻  TRY AGAIN'
                size_hint: None, None
                size: 240, 54
                on_press:
                    # สั่งรีเซ็ตด่านและวาดใหม่ทันที
                    game_board.engine.reset_level()
                    game_board.redraw()

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            GhostButton:
                text: '⌂  MAIN MENU'
                size_hint: None, None
                size: 240, 54
                on_press:
                    root.manager.current = 'menu'
                    # รีเซ็ตไว้ด้วย เผื่อกดเข้ามาเล่นใหม่จะได้ไม่ค้างหน้า Game Over
                    game_board.engine.reset_level()
                    game_board.redraw()

    # ── หน้าต่าง Level Cleared Overlay (แสดงทุกครั้งที่ผ่านด่าน) ────────────
    BoxLayout:
        id: level_complete_layout
        orientation: 'vertical'
        opacity: 0
        disabled: True
        pos_hint: {'center_y': 0.5} if self.opacity == 1 else {'center_y': 5.0}
        spacing: 20
        padding: [60, 80, 60, 80]
        canvas.before:
            Color:
                rgba: 0.02, 0.06, 0.04, 0.9  # พื้นหลังสีเขียวเข้มโปร่งแสง
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: '✔'
            font_size: 72
            color: 0.18, 0.90, 0.50, 1
            size_hint_y: None
            height: 80

        Label:
            text: 'LEVEL CLEARED!'
            font_size: 48
            bold: True
            color: 0.18, 0.90, 0.50, 1
            letter_spacing: 6
            size_hint_y: None
            height: 80

        Label:
            text: 'Great job! Ready for the next challenge?'
            font_size: 16
            color: 0.50, 0.75, 0.60, 1
            size_hint_y: None
            height: 40

        Widget:
            size_hint_y: None
            height: 30

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            NeonButton:
                text: '▶  NEXT LEVEL'
                size_hint: None, None
                size: 240, 54
                on_press:
                    # สั่งให้ GameEngine โหลดด่านถัดไป
                    game_board.engine.next_level()
                    game_board.redraw()

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            GhostButton:
                text: '⌂  MAIN MENU'
                size_hint: None, None
                size: 240, 54
                on_press:
                    root.manager.current = 'menu'
                    game_board.engine.reset_level()
                    game_board.redraw()

    # ── หน้าต่าง Game Won Overlay ──────────────────────────────────────────
    BoxLayout:
        id: game_won_layout
        orientation: 'vertical'
        opacity: 0
        disabled: True
        # เลื่อนแผ่นนี้ออกนอกจอเวลาซ่อน
        pos_hint: {'center_y': 0.5} if self.opacity == 1 else {'center_y': 5.0}
        spacing: 20
        padding: [60, 80, 60, 80]
        canvas.before:
            Color:
                rgba: 0.06, 0.05, 0.02, 0.9  # พื้นหลังสีทอง/เหลืองเข้มโปร่งแสง
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: '★ ★ ★'
            font_size: 64
            color: 0.95, 0.85, 0.20, 1  # สีเหลืองทอง
            size_hint_y: None
            height: 80

        Label:
            text: 'YOU WIN!'
            font_size: 56
            bold: True
            color: 0.95, 0.85, 0.20, 1
            letter_spacing: 8
            size_hint_y: None
            height: 80

        Label:
            text: 'Puzzle Master! All levels cleared.'
            font_size: 16
            color: 0.75, 0.70, 0.50, 1
            size_hint_y: None
            height: 40

        Widget:
            size_hint_y: None
            height: 30

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            NeonButton:
                text: '↻  PLAY AGAIN'
                size_hint: None, None
                size: 240, 54
                on_press:
                    # สั่งให้กลับไปเริ่มด่าน 1 ใหม่
                    game_board.engine.restart_game()
                    game_board.redraw()

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            GhostButton:
                text: '⌂  MAIN MENU'
                size_hint: None, None
                size: 240, 54
                on_press:
                    root.manager.current = 'menu'
                    game_board.engine.restart_game()
                    game_board.redraw()

# ── SelectLevelScreen ────────────────────────────────────────────────────────
<SelectLevelScreen>:
    canvas.before:
        Color:
            rgba: 0.05, 0.05, 0.10, 1
        Rectangle:
            pos: self.pos
            size: self.size
        # แสง Glow สวยๆ พื้นหลัง
        Color:
            rgba: 0.18, 0.90, 0.50, 0.03
        Ellipse:
            pos: self.center_x - 250, self.center_y - 250
            size: 500, 500

    BoxLayout:
        orientation: 'vertical'
        padding: [60, 40, 60, 40]
        spacing: 20

        Label:
            text: 'SELECT LEVEL'
            font_size: 42
            bold: True
            color: 0.85, 0.90, 1.00, 1
            letter_spacing: 6
            size_hint_y: None
            height: 80

        # ตารางปุ่มเลือกด่าน (สมมติจัดไว้ 6 ด่าน)
        GridLayout:
            cols: 3
            spacing: 24
            padding: [40, 20, 40, 20]

            LevelButton:
                text: '1'
                on_press: app.start_level(0)  # ด่าน 1 คือ index 0

            LevelButton:
                text: '2'
                on_press: app.start_level(1)

            LevelButton:
                text: '3'
                on_press: app.start_level(2)

            LevelButton:
                text: '4'
                on_press: app.start_level(3)

            LevelButton:
                text: '5'
                on_press: app.start_level(4)

            LevelButton:
                text: '6'
                on_press: app.start_level(5)

        Widget:
            size_hint_y: None
            height: 20

        AnchorLayout:
            size_hint_y: None
            height: 60
            anchor_x: 'center'
            GhostButton:
                text: '⌂  BACK TO MENU'
                size_hint: None, None
                size: 240, 54
                on_press: root.manager.current = 'menu'