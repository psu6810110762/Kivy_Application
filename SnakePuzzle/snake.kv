<MenuScreen>:
    BoxLayout:
        orientation: "vertical"
        spacing: 30
        padding: 80

        Label:
            text: "SNAKE PUZZLE"
            font_size: 48
            bold: True

        Button:
            text: "Start Game"
            size_hint_y: None
            height: 60
            on_press: root.manager.current = "game"

        Button:
            text: "Select Level"
            size_hint_y: None
            height: 60

        Button:
            text: "Exit"
            size_hint_y: None
            height: 60
            on_press: app.stop()